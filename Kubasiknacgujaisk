function podziel($a, $b){
    if($b == 0){
        throw new Exception("Nie mozna dzielic przez 0 !!");
    }
    return $a / $b;
}

try{
    echo "48 / 6 = " . podziel(48, 6) . "\n";
    echo "120 / 5 = " . podziel(120, 5) . "\n";
    echo "33 / 0 = " . podziel(33, 0) . "\n";
}catch(Exception $e){
    echo "Blad: " . $e->getMessage() . "\n";
}

echo "\n";

