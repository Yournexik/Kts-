<?php
// Definicja własnego wyjątku
class NieprawidlowyEmailException extends Exception {
    public function __construct($email, $message = "Nieprawidłowy email", $code = 0) {
        $fullMessage = $message . ": " . $email;
        parent::__construct($fullMessage, $code);
    }
}

// Użycie własnego wyjątku
function zarejestrujUzytkownika($email) {
    if (strpos($email, '@') === false) {
        throw new NieprawidlowyEmailException($email, "Email nie zawiera znaku @");
    }
    echo "Użytkownik zarejestrowany: $email";
}

try {
    zarejestrujUzytkownika("test@example.com");
    zarejestrujUzytkownika("zlyemailbezmalpy");
} catch (NieprawidlowyEmailException $e) {
    echo "Specyficzny błąd email: " . $e->getMessage();
} catch (Exception $e) {
    echo "Inny błąd: " . $e->getMessage();
}
?>

