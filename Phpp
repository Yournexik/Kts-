<?php
function podziel($a, $b) {
    if ($b == 0) {
        throw new DivisionByZeroError("Nie można dzielić przez zero!");
    }
    return $a / $b;
}

try {
    echo podziel(10, 2) . "<br>";   // 5
    echo podziel(8, 0);             // rzuci wyjątek
} catch (DivisionByZeroError $e) {
    echo "Błąd: " . $e->getMessage();
} catch (Throwable $e) {
    echo "Inny błąd: " . $e->getMessage();
}
?>

<?php
function sprawdzEmail($email) {
    if (strpos($email, '@') === false) {
        throw new Exception("Nieprawidłowy adres email - brakuje '@'.");
    }
    return "Email jest poprawny: " . $email;
}

try {
    echo sprawdzEmail("jan@example.com") . "<br>";
    echo sprawdzEmail("janekprzyklad.com"); // rzuci wyjątek
} catch (Exception $e) {
    echo "Błąd: " . $e->getMessage();
}
?>

<?php
try {
    $plik = 'nieistniejacy_plik.txt';
    
    if (!file_exists($plik)) {
        throw new Exception("Plik '$plik' nie istnieje!");
    }
    
    $zawartosc = file_get_contents($plik);
    echo $zawartosc;
    
} catch (Exception $e) {
    echo "Błąd: " . $e->getMessage();
} finally {
    echo "<br>Próba otwarcia pliku została zakończona.";
}
?>

