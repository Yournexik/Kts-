<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <title>Layout ze zdjęcia</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: Arial, sans-serif;
        }

        body {
            height: 100vh;
            background: #f2f2f2;
        }

        /* HEADER */
        header {
            height: 60px;
            background: #ffffff;
            border-bottom: 1px solid #ccc;
            display: flex;
            align-items: center;
            padding: 0 20px;
        }

        .logo {
            font-weight: bold;
            font-size: 18px;
            margin-right: 40px;
        }

        .menu {
            display: flex;
            gap: 15px;
        }

        .menu div {
            width: 20px;
            height: 20px;
            border: 1px solid #999;
        }

        /* MAIN LAYOUT */
        .container {
            display: flex;
            height: calc(100vh - 60px);
        }

        /* SIDEBAR */
        aside {
            width: 200px;
            background: #ffffff;
            border-right: 1px solid #ccc;
            padding: 20px;
        }

        .sidebar-item {
            height: 30px;
            border: 1px solid #bbb;
            margin-bottom: 15px;
        }

        /* CONTENT */
        main {
            flex: 1;
            padding: 20px;
        }

        .list {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
        }

        .list-item {
            height: 30px;
            flex: 1;
            border: 1px solid #bbb;
        }

        .content-box {
            height: 400px;
            border: 1px solid #999;
            background: #ffffff;
        }
    </style>
</head>
<body>

<header>
    <div class="logo">LOGO</div>
    <div class="menu">
        <div></div>
        <div></div>
        <div></div>
        <div></div>
    </div>
</header>

<div class="container">
    <aside>
        <div class="sidebar-item"></div>
        <div class="sidebar-item"></div>
        <div class="sidebar-item"></div>
        <div class="sidebar-item"></div>
    </aside>

    <main>
        <div class="list">
            <div class="list-item"></div>
            <div class="list-item"></div>
            <div class="list-item"></div>
            <div class="list-item"></div>
        </div>

        <div class="content-box"></div>
    </main>
</div>

</body>
</html>
